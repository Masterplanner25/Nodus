fn get(url, options) {
    if (options == nil) {
        return http_get(url)
    }
    return http_get(url, options)
}

fn post(url, options) {
    if (options == nil) {
        return http_post(url)
    }
    return http_post(url, options)
}

fn put(url, options) {
    if (options == nil) {
        return http_put(url)
    }
    return http_put(url, options)
}

fn delete(url, options) {
