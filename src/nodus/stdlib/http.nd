fn options(url, opts) {
    if (opts == nil) {
        return http_options_verb(url)
    }
    return http_options_verb(url, opts)
}

fn request(method, url, options) {
    if (options == nil) {
        return http_request(method, url)
    }
    return http_request(method, url, options)
}

