fn available() {
    return cb_available()
}

fn create(name, threshold, timeout) {
    return cb_create(name, threshold, timeout)
}

fn create_config(name, config) {
    return cb_create(name, config)
}

fn call(name, func) {
    return cb_call(name, func)
}

fn state(name) {
    return cb_state(name)
}

fn reset(name) {
    return cb_reset(name)
}
