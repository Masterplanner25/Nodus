fn get(name, default) {
    if (default == nil) {
        return env_get(name)
    }
    return env_get(name, default)
}

fn set(name, value) {
    return env_set(name, value)
}

fn unset(name) {
    return env_unset(name)
}

fn get_or(name, default) {
    return env_get(name, default)
}

fn delete(name) {
    return env_unset(name)
}

fn has(name) {
    return env_has(name)
}

fn list() {
    return env_list()
}

fn list_keys() {
    return env_list_keys()
}
