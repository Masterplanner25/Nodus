fn abs(value) {
    return math_abs(value)
}

fn min(a, b) {
    return math_min(a, b)
}

fn max(a, b) {
    return math_max(a, b)
}

fn floor(value) {
    return math_floor(value)
}

fn ceil(value) {
    return math_ceil(value)
}

fn sqrt(value) {
    return math_sqrt(value)
}

fn random() {
    return math_random()
}

fn parse_int(s) {
    return math_parse_int(s)
}

fn to_int(n) {
    return math_to_int(n)
}

fn to_float(n) {
    return math_to_float(n)
}

fn is_int(n) {
    return math_is_int(n)
}

fn is_float(n) {
    return math_is_float(n)
}

fn is_numeric(n) {
    return math_is_numeric(n)
}

fn idiv(a, b) {
    return math_idiv(a, b)
}

fn log(n, base) {
    if (base == nil) {
        return math_log(n)
    }
    return math_log(n, base)
}

fn pow(base_val, exp) {
    return math_pow(base_val, exp)
}

fn round(x) {
    return math_round(x)
}

fn is_nan(x) {
    return math_is_nan(x)
}

fn is_inf(x) {
    return math_is_inf(x)
}

fn is_finite(x) {
    return math_is_finite(x)
}

let nan = math_nan()
let infinity = math_infinity()
let neg_infinity = math_neg_infinity()

fn bit_and(a, b) {
    return math_bit_and(a, b)
}

fn bit_or(a, b) {
    return math_bit_or(a, b)
}

fn bit_xor(a, b) {
    return math_bit_xor(a, b)
}

fn bit_not(a) {
    return math_bit_not(a)
}

fn bit_lshift(a, n) {
    return math_bit_lshift(a, n)
}

fn bit_rshift(a, n) {
    return math_bit_rshift(a, n)
}
