# Local in-process key/value memory helpers.
fn get(key) {
    return memory_get(key)
}

fn put(key, value) {
    return memory_put(key, value)
}

fn delete(key) {
    return memory_delete(key)
}

fn keys() {
    return memory_keys()
}

fn has(key) {
    return memory_has(key)
}

fn recall_from(ns, key) {
    return memory_recall_from(ns, key)
}

fn recall_all(ns) {
    return memory_recall_all(ns)
}

fn share(ns, key, value) {
    return memory_share(ns, key, value)
}
