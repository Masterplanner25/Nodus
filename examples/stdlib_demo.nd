import "std:strings" as s
import "std:collections" as c
import "std:fs" as fs
import "std:path" as p

let items = ["a", "b", "c"]
print(s.join(items, ","))
print(c.first(items))
let more = c.push(items, "d")
print(s.join(more, "-"))
let dir = "tmp_demo"
fs.ensure_dir(dir)
let file_path = p.join(dir, "hello.txt")
fs.write(file_path, "hi")
print(fs.read(file_path))
print(fs.exists_path(file_path))
print(p.basename(file_path))
